# ============================================================
# AUTOMATIONS HOME ASSISTANT
# ============================================================
# Convention:
# - Chaque bloc correspond a un usage (protection, fermeture, ouverture)
# - Les IDs restent stables pour ne pas casser les references HA
# - Les conditions andre_mode protegent uniquement les stores salon/salle a manger

# ============================================================
# [PROTECTION ANDRE_MODE]
# ============================================================

# Si andre_mode est ON, toute tentative de fermeture sur salon/salle a manger
# est annulee en reouvrant immediatement le store concerne.
- id: 'andre_mode_block_close_living_dining'
  alias: Andre Mode | Bloquer fermeture stores salon et salle a manger
  description: Reouvre le store s'il commence a se fermer quand andre_mode est actif.
  triggers:
  - trigger: state
    entity_id:
    - cover.salon
    - cover.porte_patio
    to: closing
  conditions:
  - condition: state
    entity_id: input_boolean.andre_mode
    state: 'on'
  actions:
  - service: cover.open_cover
    data:
      entity_id: "{{ trigger.entity_id }}"
  mode: single

# ============================================================
# [FERMETURE EN FIN DE JOURNEE]
# ============================================================

# Au coucher du soleil, ferme salon + salle a manger
# uniquement si andre_mode est OFF.
- id: 'sunset_close_salon_dining_covers'
  alias: Soleil | Fermer stores salon et salle a manger
  description: Ferme les stores au coucher du soleil sauf si andre_mode est actif.
  triggers:
  - trigger: sun
    event: sunset
  conditions:
  - condition: state
    entity_id: input_boolean.andre_mode
    state: 'off'
  actions:
  - service: cover.close_cover
    target:
      entity_id:
      - cover.salon
      - cover.porte_patio
  mode: single

# ============================================================
# [OUVERTURE SAISONNIERE DES STORES]
# ============================================================

# Hiver (nov-fev): ouverture au lever du soleil.
# Hors hiver: ouverture a 07:00.
# Cibles: bureau, chambre ami, salle a manger (porte_patio), salon.
- id: 'open_covers_winter_sun_else_7am'
  alias: Stores | Ouverture saisonniere bureau Luc, chambre ami, salle a manger, salon
  description: En hiver ouvre au lever du soleil, sinon ouvre a 07:00.
  triggers:
  - trigger: sun
    event: sunrise
    id: winter_sunrise
  - trigger: time
    at: '07:00:00'
    id: non_winter_7am
  conditions: []
  actions:
  - choose:
    - conditions:
      - condition: trigger
        id: winter_sunrise
      - condition: template
        value_template: "{{ now().month in [11, 12, 1, 2] }}"
      sequence:
      - service: cover.open_cover
        target:
          entity_id:
          - cover.bureau
          - cover.chambre_amis
          - cover.porte_patio
          - cover.salon

    - conditions:
      - condition: trigger
        id: non_winter_7am
      - condition: template
        value_template: "{{ now().month not in [11, 12, 1, 2] }}"
      sequence:
      - service: cover.open_cover
        target:
          entity_id:
          - cover.bureau
          - cover.chambre_amis
          - cover.porte_patio
          - cover.salon
  mode: single

# ============================================================
# [FERMETURE SOLEIL SANS ANDRE_MODE]
# ============================================================

# Cette automatisation est volontairement independante de andre_mode.
# Elle s'applique uniquement aux stores:
# - cover.bureau
# - cover.chambre_amis
# Au coucher du soleil, ils se ferment systematiquement.
- id: 'sunset_close_bureau_and_chambre_ami_ignore_andre_mode'
  alias: Soleil | Fermer stores bureau Luc et chambre ami
  description: Ferme les stores du bureau Luc et de la chambre ami au coucher du soleil, sans condition andre_mode.
  triggers:
  - trigger: sun
    event: sunset
  conditions: []
  actions:
  - service: cover.close_cover
    target:
      entity_id:
      - cover.bureau
      - cover.chambre_amis
  mode: single

# ============================================================
# [FERMETURE CHAMBRE MAITRE AVANT SOLEIL]
# ============================================================

# Ferme le store de la chambre maitre 45 minutes avant le coucher du soleil.
# Cette automatisation est independante de andre_mode.
# - id: 'close_master_bedroom_cover_45min_before_sunset'
#   alias: Soleil | Fermer store chambre maitre 45 min avant coucher
#   description: Ferme le store de la chambre maitre 45 minutes avant le coucher du soleil.
#   triggers:
#   - trigger: sun
#     event: sunset
#     offset: '-00:45:00'
#   conditions: []
#   actions:
#   - service: cover.close_cover
#     target:
#       entity_id: cover.chambre_maitre
#   mode: single

# ============================================================
# [BUREAU LUC - FERMETURE SI ENSOLEILLE]
# ============================================================

# Jours de semaine a 13:30, si la meteo est "sunny",
# le store du bureau Luc se ferme a 75%.
# Entite meteo detectee: weather.forecast_maison
- id: 'bureau_luc_weekday_1330_if_sunny_close_75'
  alias: Bureau Luc | 13:30 semaine si soleil fermer a 75%
  description: En semaine a 13:30, ferme le store bureau a 75% si meteo ensoleillee.
  triggers:
  - trigger: time
    at: '13:30:00'
    weekday:
    - mon
    - tue
    - wed
    - thu
    - fri
  conditions:
  - condition: state
    entity_id: weather.forecast_maison
    state: sunny
  actions:
  - service: cover.set_cover_position
    target:
      entity_id: cover.bureau
    data:
      position: 75
  mode: single

# ============================================================
# [SERRURE ENTREE - REBARRER AUTO]
# ============================================================

# Si la serrure d'entree reste debarree pendant 5 minutes,
# elle est rebarree automatiquement.
- id: 'entry_lock_auto_relock_after_5min'
  alias: Entree | Rebarre serrure apres 5 min debarree
  description: Rebarre la serrure d'entree si elle reste debarree 5 minutes.
  triggers:
  - trigger: state
    entity_id: lock.porte
    to: unlocked
    for: '00:05:00'
  conditions:
  - condition: state
    entity_id: lock.porte
    state: unlocked
  actions:
  - service: lock.lock
    target:
      entity_id: lock.porte
  mode: single


# ============================================================
# [MODE TV SALON]
# ============================================================

# Quand Google TV (salon) s'allume apres 19:30, on desactive le capteur motion
# de l'entree, on eteint entree/salle a manger/foyer, on tamise le salon plafond
# et on lance la scene Rest pour la cuisine. A 22:00, on reactive le capteur.
- id: 'living_room_google_tv_mode'
  alias: Salon | Mode TV Google
  description: Ajuste la maison pour la session TV du salon, puis reactive motion a 22:00.
  triggers:
  - trigger: state
    entity_id: media_player.tv
    from: 'off'
    id: tv_on
  - trigger: time
    at: '22:00:00'
    id: restore_motion
  conditions: []
  actions:
  - choose:
    - conditions:
      - condition: trigger
        id: tv_on
      - condition: time
        after: '19:30:00'
      - condition: state
        entity_id: input_boolean.andre_mode
        state: 'off'
      - condition: state
        entity_id: input_boolean.guest_mode
        state: 'off'
      sequence:
      - service: switch.turn_off
        target:
          entity_id: switch.motion_entre_capteur_de_mouvement
      - service: light.turn_off
        target:
          entity_id:
          - light.entree
          - light.salle_a_manger
          - light.foyer
      - service: light.turn_on
        target:
          entity_id: light.salon_plafond
        data:
          brightness_pct: 20
      - service: scene.turn_on
        target:
          entity_id: scene.cuisine_rest
      - service: tts.google_translate_say
        data:
          entity_id: media_player.mini
          message: 'Bonne soirée télé'
    - conditions:
      - condition: trigger
        id: restore_motion
      sequence:
      - service: switch.turn_on
        target:
          entity_id: switch.motion_entre_capteur_de_mouvement
  mode: single


# ============================================================
# [SALLE A MANGER - ATTENUATION PROGRESSIVE 19H]
# ============================================================

# A 19:00, les lumieres de salle a manger passent progressivement
# en mode attenue sur 30 minutes si andre_mode OU guest_mode est OFF.
- id: 'dining_room_progressive_dim_19h_if_mode_off'
  alias: Salle a manger | Passage progressif en attenue a 19:00
  description: A 19:00, attenue la salle a manger sur 30 min si andre_mode ou guest_mode est OFF.
  triggers:
  - trigger: time
    at: '19:00:00'
  conditions:
  - condition: or
    conditions:
    - condition: state
      entity_id: input_boolean.andre_mode
      state: 'off'
    - condition: state
      entity_id: input_boolean.guest_mode
      state: 'off'
  actions:
  - service: light.turn_on
    target:
      entity_id: light.salle_a_manger
    data:
      brightness_pct: 35
      transition: 1800
  mode: single


# ============================================================
# [TEST BUREAU LUC - MESSAGE VOCAL 15H40]
# ============================================================

# A 15:40, envoie un message vocal sur le Google Nest Hub de Bureau Luc.
- id: 'test_bureau_luc_voice_1540'
  alias: test bureau Luc
  description: A 15:40, diffuse Bonne fin de journée Luc sur Bureau Luc Google Nest Hub.
  triggers:
  - trigger: time
    at: '15:40:00'
  conditions: []
  actions:
  - service: tts.google_translate_say
    data:
      entity_id: media_player.luc
      message: 'Bonne fin de journée Luc'
  mode: single
